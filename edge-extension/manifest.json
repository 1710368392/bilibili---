{
  "manifest_version": 3,
  "name": "Bilibili 用户备注助手",
  "version": "1.0.1",
  "description": "为 Bilibili 用户添加自定义备注，支持多标签和中国风配色",
  "author": "糖心月",
  "license": "MIT",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://space.bilibili.com/*",
    "https://message.bilibili.com/*",
    "https://search.bilibili.com/*",
    "https://t.bilibili.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/*",
        "https://space.bilibili.com/*",
        "https://message.bilibili.com/*",
        "https://search.bilibili.com/*",
        "https://t.bilibili.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.png"
  },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
